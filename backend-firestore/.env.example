# Application Configuration
PORT=8080
NODE_ENV=development

# Firebase Admin SDK Configuration
# In production, either provide the path to the service account JSON file,
# or provide the exact credentials as a base64 encoded string.
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="your-client-email@your-project.iam.gserviceaccount.com"
# WARNING: Do not wrap the private key in quotes if it contains literal \n characters and is parsed via dotenv natively,
# however for our setup, base64 encoding or a direct path is safer.
FIREBASE_PRIVATE_KEY="your-private-key"

# Alternatively, if you have the key file on disk:
# GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"

# AI Model Configuration
GEMINI_API_KEY="your-google-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
