# Application Configuration
PORT=8080
NODE_ENV=development

# Firebase Admin SDK Configuration
# In production, either provide the path to the service account JSON file,
# or provide the exact credentials as a base64 encoded string.
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="your-client-email@your-project.iam.gserviceaccount.com"
# WARNING: Do not wrap the private key in quotes if it contains literal \n characters and is parsed via dotenv natively,
# however for our setup, base64 encoding or a direct path is safer.
FIREBASE_PRIVATE_KEY="your-private-key"

# Alternatively, if you have the key file on disk:
# GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"

# AI Model Configuration
GEMINI_API_KEY="your-google-gemini-api-key"        # REQUIRED (embeddings + evaluation)
GROQ_API_KEY="your-groq-api-key"                   # REQUIRED (live chat LLM)
NVIDIA_API_KEY="your-nvidia-api-key"               # optional
OPENAI_API_KEY="your-openai-api-key"               # optional
ANTHROPIC_API_KEY="your-anthropic-api-key"         # optional
COHERE_API_KEY="your-cohere-api-key"               # optional (reranking)

# RAG & Tools
# NOTE: These were previously hardcoded in source and MUST now be provided here.
# If you used the old committed keys, ROTATE THEM — they are considered compromised.
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="edtech-ai-rag"
PINECONE_NAMESPACE="production"
TAVILY_API_KEY="your-tavily-api-key"               # optional (web search)

# Caching (optional; falls back to in-memory when unset)
REDIS_URL=""
REDIS_TOKEN=""

# Security / Ops
# Shared secret used to authenticate the CRON endpoint (POST /api/companion/evaluate).
# Send it as the `x-cron-secret` header. Leave blank in local dev.
CRON_SECRET=""
# Comma-separated allowlist of browser origins permitted by CORS in production,
# e.g. "https://app.scholarly.ai,https://www.scholarly.ai". Ignored in development (all origins allowed).
CORS_ORIGINS=""

# --- Global AI kill switch ---
# Set to true to pause ALL AI/embedding calls (zero Gemini/Groq token spend) WITHOUT
# removing your API keys. Every LLM/embedding call fails fast with an "AI_DISABLED" error.
# Requires a server/script restart to take effect. Leave false or unset for normal operation.
AI_DISABLED=false
