# Base URL of the Scholarly backend API (Express, backend-firestore).
# Admin endpoints live under `${VITE_API_URL}/admin/*`.
VITE_API_URL=http://localhost:8080/api

# Set to "true" ONLY for local development to bypass the client-side role gate.
# The backend RBAC (super_admin/admin/moderator) is always enforced regardless.
VITE_ALLOW_DEV_ADMIN=false
